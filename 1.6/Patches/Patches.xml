<?xml version="1.0" encoding="UTF-8"?>
<Patch>
	<!-- examples of flight raids for vanilla factions 
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/FactionDef[defName="Mechanoid"]/pawnGroupMakers</xpath>
		<value>
			<li Class="taranchuk_flightcombat.PawnGroupMaker_FlightRaid">
				<kindDef>Combat</kindDef>
				<commonality>10000</commonality>
				<minPoints>2000</minPoints>
				<minAircraftCount>1</minAircraftCount>
				<maxAircraftCount>2</maxAircraftCount>
				<options>
					<Mechtek_PawnKind>3</Mechtek_PawnKind>
					<Mech_Scyther>10</Mech_Scyther>
					<Mech_Pikeman>10</Mech_Pikeman>
					<Mech_Lancer>10</Mech_Lancer>
				</options>
			</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
        <xpath>Defs/FactionDef[defName="Pirate"]/pawnGroupMakers</xpath>
        <value>
            <li Class="taranchuk_flightcombat.PawnGroupMaker_FlightRaid">
                <kindDef>Combat</kindDef>
                <commonality>10000</commonality>
                <minPoints>2000</minPoints>
                <minAircraftCount>1</minAircraftCount>
                <maxAircraftCount>2</maxAircraftCount>
                <options>
					<Mechtek_PawnKind>3</Mechtek_PawnKind>
                </options>
            </li>
        </value>
    </Operation>
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/FactionDef[defName="Mechanoid" or defName="Pirate"]/raidArrivalLayerWhitelist</xpath>
        <match Class="PatchOperationAdd">
            <xpath>Defs/FactionDef[defName="Mechanoid" or defName="Pirate"]/raidArrivalLayerWhitelist</xpath>
            <value>
                <li>Orbit</li>
            </value>
        </match>
        <nomatch Class="PatchOperationAdd">
            <xpath>Defs/FactionDef[defName="Mechanoid" or defName="Pirate"]</xpath>
            <value>
                <raidArrivalLayerWhitelist>
                    <li>Orbit</li>
                </raidArrivalLayerWhitelist>
            </value>
        </nomatch>
    </Operation>
	-->
</Patch>